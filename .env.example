# Martuni configuration — loaded on startup.
# Copy this file to .env and adjust the values to your setup.
# UCI options set via setoption override these values at runtime.

# Transposition table size in MB
HASH_SIZE_MB=64

# Directory containing Polyglot opening books (.bin files).
# Searched relative to the working directory and the binary's directory.
BOOK_DIR=src/polyglot

# Opening books in priority order (comma-separated filenames, no spaces).
# The first book that contains a move for the current position is used.
# Leave empty or remove to play without a book.
BOOK_FILES=book1.bin,book2.bin
